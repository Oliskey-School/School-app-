{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=(), payment=(self)"
                }
            ]
        }
    ],
    "rewrites": [
        { "source": "/api/(.*)", "destination": "https://school-app-production-a59a.up.railway.app/api/$1" },
        { "source": "/(.*)", "destination": "/index.html" }
    ]
}