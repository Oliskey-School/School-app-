generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id                         String                    @id @default(uuid())
  name                       String
  code                       String                    @unique
  slug                       String                    @unique
  logo_url                   String?
  motto                      String?
  website                    String?
  address                    String?
  state                      String?
  email                      String?
  phone                      String?
  contact_email              String?
  subscription_status        String                    @default("trial")
  is_premium                 Boolean                   @default(false)
  is_active                  Boolean                   @default(true)
  is_onboarded               Boolean                   @default(false)
  onboarding_step            Int                       @default(1)
  plan_type                  String                    @default("free")
  trial_ends_at              DateTime?
  user_count                 Int                       @default(0)
  primary_color              String?
  secondary_color            String?
  curriculum_type            String?
  curricula_config           String[]                  @default(["NIGERIAN"])
  lga                        String?
  infrastructure_config      Json?
  settings                   Json?
  created_at                 DateTime                  @default(now())
  updated_at                 DateTime                  @updatedAt
  plan_id                    Int?
  academic_tracks            AcademicTrack[]
  announcements              Announcement[]
  anonymous_reports          AnonymousReport[]
  app_installations          AppInstallation[]
  appointments               Appointment[]
  assets                     Asset[]
  backups                    Backup[]
  branches                   Branch[]
  budgets                    Budget[]
  chat_rooms                 ChatRoom[]
  classes                    Class[]
  class_teachers             ClassTeacher[]
  counseling_appointments    CounselingAppointment[]
  curriculums                Curriculum[]
  data_requests              DataRequest[]
  educational_games          EducationalGame[]
  emergency_alerts           EmergencyAlert[]
  events                     Event[]
  exams                      Exam[]
  exam_bodies                ExamBody[]
  exam_registrations         ExamRegistration[]
  exam_results               ExamResult[]
  external_integrations      ExternalIntegration[]
  extracurricular_activities ExtracurricularActivity[]
  facilities                 Facility[]
  fees                       Fee[]
  game_scores                GameScore[]
  hostels                    Hostel[]
  inspections                Inspection[]
  invoices                   Invoice[]
  kanban_columns             KanbanColumn[]
  leave_types                LeaveType[]
  lesson_notes               LessonNote[]
  lesson_plans               LessonPlan[]
  maintenance_tickets        MaintenanceTicket[]
  messages                   Message[]
  notifications              Notification[]
  pd_courses                 PDCourse[]
  pta_meetings               PTAMeeting[]
  parents                    Parent[]
  parent_teacher_conferences ParentTeacherConference[]
  parental_consents          ParentalConsent[]
  payments                   Payment[]
  payslips                   Payslip[]
  permission_slips           PermissionSlip[]
  quizzes                    Quiz[]
  report_cards               ReportCard[]
  salary_arrears             SalaryArrear[]
  saved_reports              SavedReport[]
  savings_plans              SavingsPlan[]
  plan                       Plan?                     @relation(fields: [plan_id], references: [id])
  documents                  SchoolDocument[]
  gallery                    SchoolGallery[]
  memberships                SchoolMembership[]
  policies                   SchoolPolicy[]
  secure_anonymous_reports   SecureAnonymousReport[]
  students                   Student[]
  subjects                   Subject[]
  SubstituteAssignment       SubstituteAssignment[]
  teachers                   Teacher[]
  teacher_availabilities     TeacherAvailability[]
  salaries                   TeacherSalary[]
  timetables                 Timetable[]
  transport_routes           TransportRoute[]
  users                      User[]
  vendors                    Vendor[]
  virtual_class_sessions     VirtualClassSession[]
  visitor_logs               VisitorLog[]
  volunteer_signups          VolunteerSignup[]
  opportunities              VolunteeringOpportunity[]
  emergency_drills           EmergencyDrill[]
  incidents                  HealthIncident[]
  safeguarding_policies      SafeguardingPolicy[]
}

model Branch {
  id                     String                @id @default(uuid())
  school_id              String
  name                   String
  code                   String
  is_main                Boolean               @default(false)
  curriculum_type        String?
  location               String?
  address                String?
  phone                  String?
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  announcements          Announcement[]
  school                 School                @relation(fields: [school_id], references: [id], onDelete: Cascade)
  budgets                Budget[]
  classes                Class[]
  class_teachers         ClassTeacher[]
  exams                  Exam[]
  exam_bodies            ExamBody[]
  exam_registrations     ExamRegistration[]
  exam_results           ExamResult[]
  hostels                Hostel[]
  parents                Parent[]
  salary_arrears         SalaryArrear[]
  students               Student[]
  subjects               Subject[]
  teachers               Teacher[]
  timetables             Timetable[]
  transport_routes       TransportRoute[]
  users                  User[]
  report_cards           ReportCard[]
  virtual_class_sessions VirtualClassSession[]

  @@unique([school_id, code])
}

model User {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  password_hash          String
  full_name              String
  role                   Role                   @default(STUDENT)
  school_id              String?
  branch_id              String?
  allowed_branch_ids     String[]               @default([])
  email_verified         Boolean                @default(false)
  is_active              Boolean                @default(true)
  school_generated_id    String?
  avatar_url             String?
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt
  initial_password       String?
  audit_logs             AuditLog[]
  sent_chat_messages     ChatMessage[]
  chat_participants      ChatParticipant[]
  game_scores            GameScore[]
  received_messages      Message[]              @relation("ReceivedMessages")
  sent_messages          Message[]              @relation("SentMessages")
  notification_setting   NotificationSetting?
  parent_profile         Parent?                @relation("UserToParent")
  platform_notifications PlatformNotification[]
  memberships            SchoolMembership[]
  created_students       Student[]              @relation("StudentCreator")
  created_parents        Parent[]               @relation("ParentCreator")
  student_profile        Student?               @relation("UserToStudent")
  teacher_profile        Teacher?               @relation("UserToTeacher")
  branch                 Branch?                @relation(fields: [branch_id], references: [id])
  school                 School?                @relation(fields: [school_id], references: [id])
  sessions               UserSession[]
  verification_codes     VerificationCode[]
}

model Student {
  id                      String                    @id @default(uuid())
  user_id                 String                    @unique
  school_id               String
  branch_id               String?
  school_generated_id     String?
  full_name               String
  email                   String?
  grade                   Int?
  section                 String?
  department              String?
  gender                  String?
  dob                     DateTime?
  curriculum_type         String?
  avatar_url              String?
  status                  String                    @default("Active")
  attendance_status       String                    @default("Present")
  created_at              DateTime                  @default(now())
  updated_at              DateTime                  @updatedAt
  address                 String?
  admission_number        String?
  created_by              String?
  academic_performance    AcademicPerformance[]
  academic_tracks         AcademicTrack[]
  achievements            Achievement[]
  submissions             AssignmentSubmission[]
  attendance              Attendance[]
  behavior_notes          BehaviorNote[]
  counseling_appointments CounselingAppointment[]
  exam_results            ExamResult[]
  health_logs             HealthLog[]
  hostel_allocations      HostelAllocation[]
  hostel_visitor_logs     HostelVisitorLog[]
  invoices                Invoice[]
  parents                 ParentChild[]
  conferences             ParentTeacherConference[]
  parental_consents       ParentalConsent[]
  quiz_submissions        QuizSubmission[]
  report_cards            ReportCard[]
  savings_plans           SavingsPlan[]
  branch                  Branch?                   @relation(fields: [branch_id], references: [id])
  creator                 User?                     @relation("StudentCreator", fields: [created_by], references: [id])
  school                  School                    @relation(fields: [school_id], references: [id], onDelete: Cascade)
  user                    User                      @relation("UserToStudent", fields: [user_id], references: [id], onDelete: Cascade)
  activities              StudentActivity[]
  enrollments             StudentEnrollment[]
  fees                    StudentFee[]
  transport_assignments   TransportAssignment[]
  virtual_attendance      VirtualClassAttendance[]
  health_incidents        HealthIncident[]
}

model Teacher {
  id                       String                    @id @default(uuid())
  user_id                  String                    @unique
  school_id                String
  branch_id                String?
  allowed_branch_ids       String[]                  @default([])
  school_generated_id      String?
  full_name                String
  email                    String?
  phone                    String?
  avatar_url               String?
  status                   String                    @default("Active")
  subject_specialty        String[]
  curriculum_eligibility   String[]
  compliance_documents     Json?
  created_at               DateTime                  @default(now())
  updated_at               DateTime                  @updatedAt
  british_qualification    String?
  degree_certificate       String?
  notification_preferences Json?                     @default("{\"newSubmission\": true, \"parentMessage\": true, \"weeklySummary\": false}")
  trcn_certificate         String?
  assignments              Assignment[]
  behavior_notes           BehaviorNote[]
  classes                  ClassTeacher[]
  counseling_sessions      CounselingAppointment[]   @relation("CounselorAppointments")
  educational_games        EducationalGame[]
  leave_requests           LeaveRequest[]
  lesson_notes             LessonNote[]
  lesson_plans             LessonPlan[]
  mentee_matches           MentoringMatch[]          @relation("MenteeMatches")
  mentor_matches           MentoringMatch[]          @relation("MentorMatches")
  certificates             PDCertificate[]
  pd_enrollments           PDEnrollment[]
  conferences              ParentTeacherConference[]
  payslips                 Payslip[]
  quizzes                  Quiz[]
  resources                Resource[]
  salary_arrears           SalaryArrear[]
  branch                   Branch?                   @relation(fields: [branch_id], references: [id])
  school                   School                    @relation(fields: [school_id], references: [id], onDelete: Cascade)
  user                     User                      @relation("UserToTeacher", fields: [user_id], references: [id], onDelete: Cascade)
  attendance               TeacherAttendance[]
  availabilities           TeacherAvailability[]
  badges                   TeacherBadge[]
  office_hours             TeacherOfficeHour[]
  given_recognitions       TeacherRecognition[]      @relation("GivenRecognitions")
  recognitions             TeacherRecognition[]      @relation("TeacherRecognitions")
  salaries                 TeacherSalary[]
  timetables               Timetable[]
  virtual_classes          VirtualClassSession[]
}

model TeacherAttendance {
  id              String   @id @default(uuid())
  teacher_id      String
  school_id       String
  branch_id       String?
  date            String
  status          String
  check_in        String?
  check_out       String?
  approval_status String   @default("pending")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  teacher         Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)

  @@unique([teacher_id, date])
}

model Parent {
  id                  String                    @id @default(uuid())
  user_id             String                    @unique
  school_id           String
  branch_id           String?
  school_generated_id String?
  full_name           String
  email               String?
  phone               String?
  avatar_url          String?
  address             String?
  occupation          String?
  relationship        String?
  emergency_contact   String?
  created_at          DateTime                  @default(now())
  updated_at          DateTime                  @updatedAt
  EventRSVP           EventRSVP[]
  created_by            String?
  creator               User?                     @relation("ParentCreator", fields: [created_by], references: [id])
  branch                Branch?                   @relation(fields: [branch_id], references: [id])
  school              School                    @relation(fields: [school_id], references: [id], onDelete: Cascade)
  user                User                      @relation("UserToParent", fields: [user_id], references: [id], onDelete: Cascade)
  children            ParentChild[]
  conferences         ParentTeacherConference[]
  savings_plans       SavingsPlan[]
}

model ParentChild {
  id         String   @id @default(uuid())
  parent_id  String
  student_id String
  school_id  String
  branch_id  String?
  created_at DateTime @default(now())
  parent     Parent   @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, student_id])
}

model AcademicPerformance {
  id           String   @id @default(uuid())
  student_id   String
  school_id    String
  branch_id    String?
  subject      String
  score        Float
  term         String
  session      String
  created_at   DateTime @default(now())
  last_updated DateTime @default(now())
  student      Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([school_id, student_id, subject, term, session])
}

model BehaviorNote {
  id             String   @id @default(uuid())
  student_id     String
  teacher_id     String
  school_id      String
  branch_id      String?
  note           String
  category       String
  type           String   @default("neutral")
  points         Int      @default(0)
  parent_visible Boolean  @default(true)
  date           DateTime @default(now())
  created_at     DateTime @default(now())
  student        Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  teacher        Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
}

model SchoolMembership {
  id         String   @id @default(uuid())
  school_id  String
  user_id    String
  base_role  Role
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([school_id, user_id])
}

model Class {
  id             String              @id @default(uuid())
  school_id      String
  branch_id      String?
  name           String
  grade          Int
  section        String
  department     String?
  level_category String?
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt
  assignments    Assignment[]
  attendance     Attendance[]
  branch         Branch?             @relation(fields: [branch_id], references: [id])
  school         School              @relation(fields: [school_id], references: [id], onDelete: Cascade)
  teachers       ClassTeacher[]
  lesson_notes   LessonNote[]
  quizzes        Quiz[]
  enrollments    StudentEnrollment[]
  timetables     Timetable[]
  subjects       Subject[]           @relation("ClassToSubject")
}

model StudentEnrollment {
  id              String   @id @default(uuid())
  student_id      String
  class_id        String
  school_id       String
  branch_id       String?
  is_primary      Boolean  @default(false)
  enrollment_date DateTime @default(now())
  status          String   @default("Active")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  class           Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  student         Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, class_id])
}

model ClassTeacher {
  id         String   @id @default(uuid())
  class_id   String
  teacher_id String
  subject_id String?
  is_primary Boolean  @default(false)
  school_id  String
  branch_id  String?
  created_at DateTime @default(now())
  branch     Branch?  @relation(fields: [branch_id], references: [id])
  class      Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  subject    Subject? @relation(fields: [subject_id], references: [id])
  teacher    Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)

  @@unique([class_id, teacher_id, subject_id])
}

model Attendance {
  id         String   @id @default(uuid())
  student_id String
  class_id   String
  date       DateTime @db.Date
  status     String
  remark     String?
  created_at DateTime @default(now())
  class      Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, class_id, date])
}

model Assignment {
  id             String                 @id @default(uuid())
  class_id       String
  title          String
  description    String?
  subject        String
  due_date       DateTime
  is_published   Boolean                @default(false)
  teacher_id     String?
  attachment_url String?
  created_at     DateTime               @default(now())
  updated_at     DateTime               @updatedAt
  class          Class                  @relation(fields: [class_id], references: [id], onDelete: Cascade)
  teacher        Teacher?               @relation(fields: [teacher_id], references: [id])
  submissions    AssignmentSubmission[]
}

model AssignmentSubmission {
  id              String     @id @default(uuid())
  assignment_id   String
  student_id      String
  submitted_at    DateTime   @default(now())
  status          String     @default("Submitted")
  grade           Float?
  feedback        String?
  created_at      DateTime   @default(now())
  file_url        String?
  text_submission String?
  assignment      Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  student         Student    @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, assignment_id])
}

model ReportCard {
  id                      String   @id @default(uuid())
  school_id               String
  student_id              String
  branch_id               String?
  session                 String
  term                    String
  class_id                String?
  total_score             Decimal?
  average_score           Decimal?
  position_in_class       Int?
  total_students_in_class Int?
  attendance_count        Int?
  principal_remark        String?
  teacher_remark          String?
  academic_records        Json?
  is_published            Boolean  @default(false)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt
  status                  String   @default("Draft")
  branch                  Branch?  @relation(fields: [branch_id], references: [id])
  school                  School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student                 Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model Fee {
  id              String       @id @default(uuid())
  school_id       String
  title           String
  description     String?
  amount          Float
  due_date        DateTime
  curriculum_type String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  school          School       @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student_fees    StudentFee[]
}

model StudentFee {
  id          String   @id @default(uuid())
  student_id  String
  fee_id      String?
  paid_amount Float    @default(0)
  status      String   @default("Pending")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  amount      Float
  branch_id   String?
  due_date    DateTime
  school_id   String
  title       String
  fee         Fee?     @relation(fields: [fee_id], references: [id])
  student     Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model Payment {
  id             String   @id @default(uuid())
  school_id      String
  branch_id      String?
  student_id     String?
  fee_id         String?
  amount         Float
  payment_date   DateTime @default(now())
  payment_method String
  reference      String?
  status         String   @default("Completed")
  purpose        String?
  metadata       Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  school         School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
}

model Announcement {
  id         String   @id @default(uuid())
  school_id  String
  branch_id  String?
  title      String
  content    String
  category   String
  is_pinned  Boolean  @default(false)
  image_url  String?
  audience   String[]
  created_at DateTime @default(now())
  branch     Branch?  @relation(fields: [branch_id], references: [id])
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
}

model Event {
  id           String      @id @default(uuid())
  school_id    String
  branch_id    String?
  title        String
  description  String?
  date         DateTime
  type         String
  location     String?
  rsvp_enabled Boolean     @default(true)
  created_at   DateTime    @default(now())
  school       School      @relation(fields: [school_id], references: [id], onDelete: Cascade)
  rsvps        EventRSVP[]
}

model EventRSVP {
  id         String   @id @default(uuid())
  event_id   String
  parent_id  String
  status     String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  parent     Parent   @relation(fields: [parent_id], references: [id], onDelete: Cascade)

  @@unique([event_id, parent_id])
}

model SavingsPlan {
  id             String   @id @default(uuid())
  school_id      String
  parent_id      String
  student_id     String
  target_amount  Float
  current_amount Float    @default(0)
  target_date    DateTime
  frequency      String
  is_active      Boolean  @default(true)
  is_deleted     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  parent         Parent   @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  school         School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student        Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model TeacherOfficeHour {
  id          String   @id @default(uuid())
  teacher_id  String
  day_of_week Int
  start_time  String
  end_time    String
  created_at  DateTime @default(now())
  teacher     Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(uuid())
  school_id  String
  branch_id  String?
  user_id    String?
  title      String
  message    String
  category   String   @default("System")
  audience   String[]
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
}

model Appointment {
  id          String   @id @default(uuid())
  school_id   String
  branch_id   String?
  parent_id   String?
  teacher_id  String?
  student_id  String?
  title       String
  description String?
  date        DateTime
  status      String   @default("Pending")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  school      School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
}

model VolunteeringOpportunity {
  id           String            @id @default(uuid())
  school_id    String
  branch_id    String?
  title        String
  description  String?
  date         DateTime?
  time         String?
  role         String?
  status       String            @default("Open")
  slots_total  Int               @default(0)
  slots_filled Int               @default(0)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
  signups      VolunteerSignup[]
  school       School            @relation(fields: [school_id], references: [id], onDelete: Cascade)
}

model VolunteerSignup {
  id             String                  @id @default(uuid())
  opportunity_id String
  school_id      String
  branch_id      String?
  parent_id      String?
  full_name      String
  email          String?
  phone          String?
  created_at     DateTime                @default(now())
  opportunity    VolunteeringOpportunity @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)
  school         School                  @relation(fields: [school_id], references: [id], onDelete: Cascade)
}

model VerificationCode {
  id         String    @id @default(uuid())
  user_id    String
  email      String
  code       String
  purpose    String    @default("email_verification")
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  attempts   Int       @default(0)
  ip_address String?
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([email])
  @@index([code])
}

model TransportBus {
  id           String   @id @default(uuid())
  school_id    String
  branch_id    String?
  name         String
  driver_name  String?
  plate_number String?
  capacity     Int      @default(0)
  status       String   @default("active")
  route_name   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model TransportRoute {
  id                  String                @id @default(uuid())
  school_id           String
  branch_id           String?
  route_name          String
  bus_number          String
  driver_name         String
  driver_phone        String?
  capacity            Int
  morning_departure   String?
  afternoon_departure String?
  status              String                @default("active")
  monthly_fee         Float                 @default(0)
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt
